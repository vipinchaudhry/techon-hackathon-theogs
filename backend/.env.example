# Copy to ".env" only if you want to override defaults. Everything here is OPTIONAL.

# --- LLM (OpenRouter) ---
# Easiest: put your key in techon/api.md instead. If you'd rather use an env var:
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# Cheapest test model is the default. Override the model here if you want:
# LLM_MODEL=google/gemini-2.0-flash-lite-001

# Force mock mode (no network, no spend) even if a key exists:
# LLM_MOCK=1

# Hard stop for the testing budget, in USD (default 20):
# LLM_TEST_BUDGET_USD=20

# --- Database ---
# Default is a local SQLite file (zero setup). To use Postgres instead:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/navigator
# (and uncomment psycopg in requirements.txt, then: pip install -r requirements.txt)
